# Database
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# AI Gateway (Vercel) — provides both Anthropic Sonnet and OpenAI embeddings under one key
AI_GATEWAY_API_KEY=

# Spending controls
DAILY_LLM_SPEND_CAP_USD=200

# Kill switches
# Set to "cache_only" to disable live LLM calls (fallback to cached responses only)
PANEL_LIVE_MODE=

# Prompt version (increment on persona prompt changes to invalidate cache)
PROMPT_VERSION=v1
